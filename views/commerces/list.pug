.box
  h2.subtitle Listado de Comercios

  table.table.is-fullwidth.is-striped
    thead
      tr
        th Estado
        th Razón Social
        th CUIT
        th Email
        th Teléfono
        th Dirección
        th Acciones
    tbody
      each commerce in commerces
        tr
          td
            if commerce.status === 1
              span.tag.is-success Activo
            else if commerce.status === 0
              span.tag.is-danger Inactivo
            else
              span.tag.is-light Pendiente
          td= commerce.name
          td= commerce.cuit
          td= commerce.email
          td= commerce.phone
          td= commerce.address
          td
            //- button.button.is-small.mr-1(href="/commerces/" + commerce.cuit) Editar
            button.button.is-small.is-danger(onclick=`deleteCommerce(${commerce.cuit})`) Eliminar

  script.
    async function deleteCommerce(cuit) {
      if (!confirm('¿Está seguro de eliminar este comercio?')) return;

      try {
        const response = await fetch(`/api/commerces/${cuit}`, { method: 'DELETE' });
        console.log(response);
        if (response.ok) {
          alert('Comercio eliminado exitosamente.');
          location.reload();
        } else {
          const errorData = await response.json();
          alert('Error al eliminar el comercio: ' + errorData.error);
        }
      } catch (error) {
        alert('Error de red al eliminar el comercio.');
      }
    }

