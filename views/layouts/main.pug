doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title #{title || 'Mi App'}

    // Bulma CSS CDN
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css")

  body
    // Navbar reutilizable
    include ./navbar

    // Contenido dinámico de cada vista
    section.section
      .container
        block content
